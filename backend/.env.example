# Copy this file to `.env` and adjust as needed.
# `.env` is gitignored; `.env.example` is committed so others know what to set.

# Port the API server listens on
PORT=4000

# Environment: "development" exposes error stacks; "production" hides them
NODE_ENV=development

# Comma-separated list of origins allowed to call the API (CORS).
# Must include the frontend URL. Next.js dev defaults to :3000 but falls back
# to :3001/:3002 if that port is busy, so a few are listed here.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002
